{
	"$schema": "https://json-schema.org/draft-07/schema",
	"$id": "repo-map.schema.json",
	"title": "Pi Repo Map config",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"$schema": { "type": "string" },
		"scan": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"max_files": { "type": "integer", "minimum": 1, "maximum": 1000000 },
				"max_file_bytes": { "type": "integer", "minimum": 1, "maximum": 104857600 },
				"concurrency": { "type": "integer", "minimum": 1, "maximum": 32 }
			}
		},
		"cache": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"max_generations": { "type": "integer", "minimum": 1, "maximum": 10 }
			}
		}
	}
}
