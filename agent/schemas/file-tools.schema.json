{
	"$schema": "https://json-schema.org/draft-07/schema",
	"$id": "file-tools.schema.json",
	"title": "Pi file-tools config",
	"type": "object",
	"additionalProperties": false,
	"required": ["version"],
	"properties": {
		"$schema": {
			"type": "string"
		},
		"version": {
			"const": 1
		},
		"blocked_path": {
			"type": "array",
			"default": [".git/"],
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"ignored_path": {
			"type": "array",
			"default": [],
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"limits": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"ls_entries": {
					"type": "integer",
					"minimum": 1,
					"maximum": 10000,
					"default": 200
				},
				"read_lines": {
					"type": "integer",
					"minimum": 1,
					"maximum": 100000,
					"default": 2000
				},
				"read_bytes": {
					"type": "integer",
					"minimum": 1024,
					"maximum": 10485760,
					"default": 51200
				},
				"find_output_token_budget": {
					"type": "integer",
					"minimum": 100,
					"maximum": 10000,
					"default": 800
				},
				"find_flat_result_limit": {
					"type": "integer",
					"minimum": 0,
					"maximum": 10000,
					"default": 5
				},
				"find_grouped_result_limit": {
					"type": "integer",
					"minimum": 0,
					"maximum": 10000,
					"default": 40
				},
				"find_max_matches_scanned": {
					"type": "integer",
					"minimum": 1,
					"maximum": 1000000,
					"default": 100000
				},
				"find_max_exact_paths": {
					"type": "integer",
					"minimum": 1,
					"maximum": 10000,
					"default": 200
				},
				"grep_matching_lines": {
					"type": "integer",
					"minimum": 1,
					"maximum": 200,
					"default": 40
				},
				"grep_max_matching_lines": {
					"type": "integer",
					"minimum": 1,
					"maximum": 200,
					"default": 200
				},
				"grep_model_output_chars": {
					"type": "integer",
					"minimum": 1000,
					"maximum": 50000,
					"default": 8000
				},
				"grep_snippet_chars": {
					"type": "integer",
					"minimum": 40,
					"maximum": 1000,
					"default": 240
				},
				"grep_context_lines": {
					"type": "integer",
					"minimum": 0,
					"maximum": 3,
					"default": 3
				},
				"grep_max_file_bytes": {
					"type": "integer",
					"minimum": 1024,
					"maximum": 104857600,
					"default": 1048576
				},
				"grep_max_files_scanned": {
					"type": "integer",
					"minimum": 1,
					"maximum": 1000000,
					"default": 100000
				}
			}
		},
		"ignore": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"piignore": {
					"type": "boolean",
					"default": true
				},
				"gitignore": {
					"type": "boolean",
					"default": true
				},
				"git_tracked_files_bypass": {
					"type": "boolean",
					"default": true
				},
				"builtin_profile": {
					"type": "string",
					"enum": ["none", "minimal", "performance"],
					"default": "minimal"
				}
			}
		}
	}
}
