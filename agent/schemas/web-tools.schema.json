{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"$schema": { "type": "string" },
		"network": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"fake_ip_ranges": {
					"type": "array",
					"maxItems": 8,
					"uniqueItems": true,
					"items": {
						"type": "string",
						"pattern": "^198\\.(18|19)\\.[0-9]{1,3}\\.[0-9]{1,3}\\/(1[5-9]|2[0-9]|3[0-2])$"
					},
					"default": []
				}
			}
		},
		"websearch": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"provider_order": {
					"type": "array",
					"minItems": 1,
					"maxItems": 8,
					"items": { "enum": ["exa_mcp", "duckduckgo_html"] },
					"default": ["exa_mcp", "duckduckgo_html"]
				},
				"fallback": { "type": "boolean", "default": true },
				"default_results": { "type": "integer", "minimum": 1, "maximum": 20, "default": 8 },
				"cache_ttl_seconds": { "type": "integer", "minimum": 0, "maximum": 86400, "default": 300 },
				"exa_mcp": {
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"enabled": { "type": "boolean", "default": true },
						"url": {
							"type": "string",
							"pattern": "^https?://",
							"default": "https://mcp.exa.ai/mcp?tools=web_search_exa"
						},
						"tool": { "type": "string", "minLength": 1, "maxLength": 128, "default": "web_search_exa" },
						"api_key_env": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z_][A-Za-z0-9_]*$", "default": "EXA_API_KEY" },
						"timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 60, "default": 12 },
						"type": { "type": "string", "minLength": 1, "maxLength": 64, "default": "auto" }
					}
				},
				"duckduckgo_html": {
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"enabled": { "type": "boolean", "default": true },
						"timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 60, "default": 15 },
						"user_agent": { "type": "string", "minLength": 1, "maxLength": 512 },
						"region": {
							"type": "string",
							"minLength": 2,
							"maxLength": 32,
							"pattern": "^[a-z0-9-]+$",
							"default": "wt-wt"
						},
						"response_bytes": { "type": "integer", "minimum": 65536, "maximum": 5242880, "default": 2097152 },
						"min_interval_seconds": { "type": "integer", "minimum": 0, "maximum": 3600, "default": 15 },
						"blocked_cooldown_seconds": { "type": "integer", "minimum": 0, "maximum": 86400, "default": 600 }
					}
				}
			}
		},
		"webfetch": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 120, "default": 30 },
				"max_redirects": { "type": "integer", "minimum": 0, "maximum": 10, "default": 5 },
				"user_agent": { "type": "string", "minLength": 1, "maxLength": 512, "default": "pi-webfetch/1.0" },
				"limits": {
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"response_bytes": { "type": "integer", "minimum": 65536, "maximum": 52428800, "default": 10485760 },
						"default_output_chars": { "type": "integer", "minimum": 1000, "maximum": 100000, "default": 20000 },
						"max_output_chars": { "type": "integer", "minimum": 1000, "maximum": 100000, "default": 100000 }
					}
				},
				"cookies": {
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"enabled": { "type": "boolean", "default": true },
						"domains": {
							"type": "array",
							"maxItems": 100,
							"uniqueItems": true,
							"items": {
								"type": "string",
								"minLength": 1,
								"pattern": "^(\\*\\.)?[A-Za-z0-9.-]+$"
							},
							"default": []
						},
						"confirmation": {
							"enum": ["always", "session", "never"],
							"default": "session"
						}
					}
				}
			}
		}
	}
}
