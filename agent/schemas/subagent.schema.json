{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"$schema": { "type": "string" },
		"default_model": { "type": ["string", "null"] },
		"max_parallel_tasks": { "type": "integer", "minimum": 1, "maximum": 32 },
		"max_concurrency": { "type": "integer", "minimum": 1, "maximum": 8 },
		"timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 3600000 },
		"retries": { "type": "integer", "minimum": 0, "maximum": 5 },
		"retry_delay_ms": { "type": "integer", "minimum": 0, "maximum": 60000 },
		"retry_on_empty_output": { "type": "boolean" },
		"retry_on_timeout": { "type": "boolean" },
		"max_inline_output_tokens": { "type": "integer", "minimum": 250, "maximum": 50000 },
		"max_handoff_tokens": { "type": "integer", "minimum": 250, "maximum": 50000 },
		"agent_scope": { "const": "user" },
		"allow_project_agents": { "type": "boolean" },
		"project_agents_override_user": { "type": "boolean" },
		"confirm_write_agents": { "type": "boolean" },
		"default_tools": {
			"type": "array",
			"minItems": 1,
			"items": { "type": "string", "minLength": 1 }
		},
		"agent_overrides": {
			"type": "object",
			"additionalProperties": {
				"type": "object",
				"additionalProperties": false,
				"properties": {
					"model": { "type": ["string", "null"] },
					"tools": {
						"type": "array",
						"minItems": 1,
						"items": { "type": "string", "minLength": 1 }
					}
				}
			}
		}
	}
}
