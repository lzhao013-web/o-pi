{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"$schema": { "type": "string" },
		"enabled": { "type": "boolean", "default": true },
		"exclude_paths": {
			"type": "array",
			"maxItems": 100,
			"default": [],
			"items": { "type": "string", "minLength": 1, "maxLength": 1024 },
			"uniqueItems": true
		},
		"startup_timeout_ms": { "type": "integer", "minimum": 100, "maximum": 60000, "default": 8000 },
		"request_timeout_ms": { "type": "integer", "minimum": 100, "maximum": 60000, "default": 5000 },
		"idle_timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 3600000, "default": 300000 },
		"max_restarts": { "type": "integer", "minimum": 0, "maximum": 10, "default": 2 },
		"diagnostics": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"enabled": { "type": "boolean", "default": true },
				"max_wait_ms": { "type": "integer", "minimum": 0, "maximum": 60000, "default": 3000 },
				"settle_ms": { "type": "integer", "minimum": 0, "maximum": 5000, "default": 150 },
				"max_items": { "type": "integer", "minimum": 0, "maximum": 100, "default": 8 },
				"min_severity": { "enum": ["error", "warning", "information", "hint"], "default": "warning" }
			}
		},
		"read": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"outline": { "type": "boolean", "default": true },
				"max_symbols": { "type": "integer", "minimum": 0, "maximum": 200, "default": 40 }
			}
		},
		"grep": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"workspace_symbols": { "type": "boolean", "default": true },
				"references": { "type": "boolean", "default": false },
				"max_symbols": { "type": "integer", "minimum": 0, "maximum": 200, "default": 20 },
				"max_references": { "type": "integer", "minimum": 0, "maximum": 200, "default": 20 }
			}
		},
		"servers": {
			"type": "array",
			"maxItems": 50,
			"default": [],
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": ["id", "command", "extensions"],
				"properties": {
					"id": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[A-Za-z0-9_-]+$" },
					"enabled": { "type": "boolean", "default": true },
					"command": { "type": "string", "minLength": 1, "maxLength": 512 },
					"args": {
						"type": "array",
						"maxItems": 64,
						"items": { "type": "string", "maxLength": 512 },
						"default": []
					},
					"extensions": {
						"type": "array",
						"minItems": 1,
						"maxItems": 64,
						"uniqueItems": true,
						"items": { "type": "string", "pattern": "^\\.[A-Za-z0-9_+-]+$" }
					},
					"initialization_options": { "type": "object" }
				}
			}
		}
	}
}
