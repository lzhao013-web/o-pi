{
	"$schema": "https://json-schema.org/draft-07/schema",
	"$id": "bash-tool.schema.json",
	"title": "Pi bash-tool config",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"$schema": {
			"type": "string"
		},
		"default_timeout_seconds": {
			"type": "integer",
			"minimum": 1,
			"maximum": 86400,
			"default": 120
		},
		"limits": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"success_output_bytes": {
					"type": "integer",
					"minimum": 1024,
					"maximum": 1048576,
					"default": 24576
				},
				"failure_output_bytes": {
					"type": "integer",
					"minimum": 1024,
					"maximum": 1048576,
					"default": 49152
				},
				"live_output_bytes": {
					"type": "integer",
					"minimum": 1024,
					"maximum": 262144,
					"default": 8192
				},
				"max_capture_bytes": {
					"type": "integer",
					"minimum": 1024,
					"maximum": 1073741824,
					"default": 268435456
				}
			}
		},
		"safety": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"deny_patterns": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					},
					"default": []
				},
				"deny_regex": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					},
					"default": []
				}
			}
		}
	}
}
