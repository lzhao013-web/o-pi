{
	"$schema": "./permissions.schema.json",
	"version": 1,
	"profile": "standard",
	"files": {
		"roots": [
			{ "path": "${workspace}", "access": "read-write" },
			{ "path": "~/datasets", "access": "read-only" }
		],
		"outsideRoots": {
			"read": "ask",
			"write": "ask"
		},
		"rules": {
			"deny": [
				{ "paths": ["~/.ssh/**", "~/.gnupg/**"], "access": ["read", "write"] }
			],
			"ask": [
				{ "paths": ["**/.env", "**/.env.*"], "access": ["read"] }
			],
			"allow": []
		}
	},
	"tools": {
		"default": "ask",
		"items": {
			"ls": "allow",
			"read": "allow",
			"edit": "allow",
			"bash": {
				"default": "ask",
				"commands": {
					"deny": ["sudo *", "rm -rf /", "rm -rf /*"],
					"ask": ["git push *", "npm publish *"],
					"allow": ["git status", "git diff *", "npm test *", "pytest *"]
				}
			}
		}
	},
	"mcp": { "default": "ask", "servers": {} },
	"skills": { "default": "ask", "items": {} },
	"agents": { "default": "ask", "items": {} },
	"audit": { "enabled": true }
}
