{
	"$schema": "../schemas/subagent.schema.json",
	"default_model": null,
	"max_parallel_tasks": 4,
	"max_concurrency": 1,
	"timeout_ms": 600000,
	"retries": 1,
	"retry_delay_ms": 1000,
	"retry_on_empty_output": true,
	"retry_on_timeout": false,
	"max_inline_output_tokens": 8000,
	"max_handoff_tokens": 6000,
	"agent_scope": "user",
	"allow_project_agents": false,
	"project_agents_override_user": false,
	"confirm_write_agents": true,
	"default_tools": ["read", "grep", "find", "ls"]
}
