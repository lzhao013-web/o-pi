{
	"$schema": "../schemas/web-tools.schema.json",
	"version": 1,

	"webfetch": {
		// 单次请求总时间，包括重定向和正文读取。
		"timeout_seconds": 30,

		// 每个重定向目标都会重新执行 URL、DNS 和 Cookie 检查。
		"max_redirects": 5,

		// 可在需要复用浏览器登录态的站点按需手动调整。
		"user_agent": "pi-webfetch/1.0",

		"network": {
			// Clash/mihomo TUN fake-ip 可填 ["198.18.0.0/15"] 或更窄范围。
			// 仅放行域名 DNS 解析得到的 fake-ip；URL 直接写 IP 仍会拒绝。
			"fake_ip_ranges": [
				"198.18.0.0/15"
			]
		},

		"limits": {
			// 解压后允许读取的最大响应正文。
			"response_bytes": 10485760,

			// 未传 limit 时返回给模型的字符数。
			"default_output_chars": 20000,

			// 模型单次调用可请求的最大字符数。
			"max_output_chars": 100000
		},

		"cookies": {
			"enabled": true,

			// example.com 只匹配自身；*.example.com 只匹配子域名。
			"domains": [
				"*.reddit.com",
				"*.youtube.com",
				"*.bilibili.com"
			],

			// always: 每次询问；session: 每个 origin 每会话首次询问；never: 命中后直接发送。
			"confirmation": "session"
		}
	}
}
